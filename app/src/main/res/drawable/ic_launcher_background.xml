<?xml version="1.0" encoding="utf-8"?>
<!--
    Solid white background for the ChibiClaw adaptive launcher icon.
    The logo is dark blue/black, so white gives the highest contrast
    and reads well against any wallpaper a launcher paints behind it.
    Layered beneath `ic_launcher_foreground` (which lives in mipmap-*
    as PNGs) via `mipmap-anydpi/ic_launcher.xml`.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M0,0h108v108h-108z" />
</vector>
